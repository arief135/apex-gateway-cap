{
    "_version": "1.84.0",
    "sap.app": {
        "id": "id.apnv.apex.ui.adminui",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "0.0.1"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "resources": "resources.json",
        "sourceTemplate": {
            "id": "@sap/generator-fiori:basic",
            "version": "1.24.0",
            "toolsId": "19e7ea79-862e-40a7-944e-1f8011fed990"
        },
        "dataSources": {
            "mainService": {
                "uri": "/odata/v4/gateway/",
                "type": "OData",
                "settings": {
                    "annotations": [],
                    "odataVersion": "4.01"
                }
            }
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "",
            "favIcon": "",
            "phone": "",
            "phone@2": "",
            "tablet": "",
            "tablet@2": ""
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": true,
        "dependencies": {
            "minUI5Version": "1.147.2",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "id.apnv.apex.ui.adminui.i18n.i18n"
                }
            },
            "": {
                "dataSource": "mainService",
                "preload": true,
                "settings": {
                    "operationMode": "Server",
                    "autoExpandSelect": true,
                    "earlyRequests": true
                }
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "routing": {
            "config": {
                "routerClass": "sap.m.routing.Router",
                "controlAggregation": "pages",
                "controlId": "pageContainer",
                "transition": "slide",
                "type": "View",
                "viewType": "XML",
                "async": true
            },
            "routes": [
                {
                    "name": "RouteMain",
                    "pattern": ":?query:",
                    "target": [
                        "TargetMain"
                    ]
                },
                {
                    "name": "RoutePage",
                    "pattern": "Routes:?query:",
                    "target": {
                        "name": "TargetRoute",
                        "prefix": "n"
                    }
                },
                {
                    "name": "DestinationPage",
                    "pattern": "Destinations:?query:",
                    "target": {
                        "name": "TargetDestination",
                        "prefix": "n"
                    }
                }
            ],
            "targets": {
                "TargetMain": {
                    "id": "Main",
                    "name": "id.apnv.apex.ui.adminui.view.Main"
                },
                "TargetRoute": {
                    "id": "RouteContainer",
                    "type": "Component",
                    "name": "id.apnv.apex.ui.routeman"
                },
                "TargetDestination": {
                    "id": "DestinationContainer",
                    "type": "Component",
                    "name": "id.apnv.apex.ui.destinationman"
                }
            }
        },
        "rootView": {
            "viewName": "id.apnv.apex.ui.adminui.view.App",
            "type": "XML",
            "id": "App",
            "async": true
        }
    }
}