<mvc:View
    controllerName="id.apnv.apex.ui.adminui.controller.App"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
>
    <App id="app">
        <tnt:ToolPage id="toolPage">
            <tnt:header>
                <tnt:ToolHeader id="_IDGenToolHeader1">
                    <Button
                        id="sideNavigationToggleButton"
                        icon="sap-icon://menu2"
                        type="Transparent"
                        press=".onSideNavButtonPress"
                    >
                        <layoutData>
                            <OverflowToolbarLayoutData
                                id="_IDGenOverflowToolbarLayoutData"
                                priority="NeverOverflow"
                            />
                        </layoutData>
                    </Button>
                    <ToolbarSpacer
                        id="_IDGenToolbarSpacer"
                        width="20px"
                    />
                    <Button
                        id="_IDGenButton"
                        text="File"
                        type="Transparent"
                    >
                        <layoutData>
                            <OverflowToolbarLayoutData
                                id="_IDGenOverflowToolbarLayoutData1"
                                priority="Low"
                            />
                        </layoutData>
                    </Button>
                    <Button
                        id="_IDGenButton1"
                        text="Edit"
                        type="Transparent"
                    >
                        <layoutData>
                            <OverflowToolbarLayoutData
                                id="_IDGenOverflowToolbarLayoutData2"
                                priority="Low"
                            />
                        </layoutData>
                    </Button>
                    <Button
                        id="_IDGenButton2"
                        text="View"
                        type="Transparent"
                    >
                        <layoutData>
                            <OverflowToolbarLayoutData
                                id="_IDGenOverflowToolbarLayoutData3"
                                priority="Low"
                            />
                        </layoutData>
                    </Button>
                    <Button
                        id="_IDGenButton3"
                        text="Navigate"
                        type="Transparent"
                    >
                        <layoutData>
                            <OverflowToolbarLayoutData
                                id="_IDGenOverflowToolbarLayoutData4"
                                priority="Low"
                            />
                        </layoutData>
                    </Button>
                    <Button
                        id="_IDGenButton4"
                        text="Code"
                        type="Transparent"
                    >
                        <layoutData>
                            <OverflowToolbarLayoutData
                                id="_IDGenOverflowToolbarLayoutData5"
                                priority="Low"
                            />
                        </layoutData>
                    </Button>
                    <Button
                        id="_IDGenButton5"
                        text="Refactor"
                        type="Transparent"
                    >
                        <layoutData>
                            <OverflowToolbarLayoutData
                                id="_IDGenOverflowToolbarLayoutData6"
                                priority="Low"
                            />
                        </layoutData>
                    </Button>
                    <Button
                        id="_IDGenButton6"
                        text="Run"
                        type="Transparent"
                    >
                        <layoutData>
                            <OverflowToolbarLayoutData
                                id="_IDGenOverflowToolbarLayoutData7"
                                priority="Low"
                            />
                        </layoutData>
                    </Button>
                    <Button
                        id="_IDGenButton7"
                        text="Tools"
                        type="Transparent"
                    >
                        <layoutData>
                            <OverflowToolbarLayoutData
                                id="_IDGenOverflowToolbarLayoutData8"
                                priority="Low"
                            />
                        </layoutData>
                    </Button>
                    <tnt:ToolHeaderUtilitySeparator
                        id="_IDGenToolHeaderUtilitySeparator"
                    />
                    <ToolbarSpacer id="_IDGenToolbarSpacer1">
                        <layoutData>
                            <OverflowToolbarLayoutData
                                id="_IDGenOverflowToolbarLayoutData9"
                                priority="NeverOverflow"
                                minWidth="20px"
                            />
                        </layoutData>
                    </ToolbarSpacer>
                    <Button
                        id="_IDGenButton8"
                        text="Alan Smith"
                        type="Transparent"
                        press=".handleUserNamePress"
                        ariaHasPopup="Menu"
                    >
                        <layoutData>
                            <OverflowToolbarLayoutData
                                id="_IDGenOverflowToolbarLayoutData10"
                                priority="NeverOverflow"
                            />
                        </layoutData>
                    </Button>
                </tnt:ToolHeader>
            </tnt:header>
            <tnt:sideContent>
                <tnt:SideNavigation
                    id="_IDGenSideNavigation"
                    expanded="true"
                    itemPress=".onItemPress"
                    selectedKey="{sideMenu>/selectedKey}"
                    itemSelect=".onItemSelect"
                >
                    <tnt:NavigationList
                        id="_IDGenNavigationList"
                        items="{path: 'sideMenu>/navigation'}"
                    >
                        <tnt:NavigationListItem
                            id="_IDGenNavigationListItem"
                            text="{sideMenu>title}"
                            icon="{sideMenu>icon}"
                            enabled="{sideMenu>enabled}"
                            expanded="{sideMenu>expanded}"
                            items="{sideMenu>items}"
                            selectable="{= ${sideMenu>items}.length > 3}"
                            key="{sideMenu>key}"
                        >
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem1"
                                text="{sideMenu>title}"
                                key="{sideMenu>key}"
                                enabled="{sideMenu>enabled}"
                            />
                        </tnt:NavigationListItem>
                    </tnt:NavigationList>
                    <tnt:fixedItem>
                        <tnt:NavigationList
                            id="_IDGenNavigationList1"
                            items="{path: 'sideMenu>/fixedNavigation'}"
                        >
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem2"
                                text="{sideMenu>title}"
                                icon="{sideMenu>icon}"
                                ariaHasPopup="{sideMenu>ariaHasPopup}"
                                design="{sideMenu>design}"
                                press=".onQuickActionPress"
                                selectable="{selectable}"
                            />
                        </tnt:NavigationList>
                    </tnt:fixedItem>
                </tnt:SideNavigation>
            </tnt:sideContent>
            <tnt:mainContents>
                <NavContainer
                    id="pageContainer"
                />
            </tnt:mainContents>
        </tnt:ToolPage>
    </App>
</mvc:View>
